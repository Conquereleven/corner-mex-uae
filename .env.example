# Browser-safe Supabase configuration. Publishable keys are public identifiers, not service-role secrets.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_CORNERMEX_CHECKOUT_ENABLED=false

# Server-only configuration. Never prefix service-role or integration secrets with VITE_.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
RESEND_API_KEY=

CORNERMEX_COMMERCE_MODEL=single_merchant
CORNERMEX_MARKETPLACE_ENABLED=false
CORNERMEX_SELLER_AUTH_ENABLED=false
CORNERMEX_SELLER_PAYOUTS_ENABLED=false
CORNERMEX_COMMISSIONS_ENABLED=false
CORNERMEX_CHECKOUT_ENABLED=false
CORNERMEX_EXTERNAL_EMAIL_ENABLED=false
CORNERMEX_EXTERNAL_MESSAGES_ENABLED=false
CORNERMEX_REAL_PAYMENT_EXECUTION_ENABLED=false
