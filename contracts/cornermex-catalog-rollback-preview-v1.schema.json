{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "executionId",
    "targetProject",
    "productIds",
    "objectPaths",
    "reviewIds",
    "untouched",
    "fingerprint",
    "writes"
  ],
  "properties": {
    "contractVersion": { "const": "cornermex-catalog-rollback-preview-v1" },
    "executionId": { "type": "string" },
    "targetProject": { "type": "string", "not": { "const": "wlrfknmrhowldygmvtvn" } },
    "productIds": { "type": "array", "items": { "type": "string" } },
    "objectPaths": { "type": "array", "items": { "type": "string" } },
    "reviewIds": { "type": "array", "items": { "type": "string" } },
    "untouched": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inventory", "orders", "payments", "productReviews"],
      "properties": {
        "inventory": { "const": true },
        "orders": { "const": true },
        "payments": { "const": true },
        "productReviews": { "const": true }
      }
    },
    "fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "writes": { "const": false }
  }
}
