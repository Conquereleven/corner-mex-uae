{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cornerops-cornermex-catalog-export-v1",
  "type": "object",
  "required": [
    "contractVersion",
    "sourceRepoSha",
    "sourceFingerprint",
    "sourceCount",
    "classificationCounts",
    "records"
  ],
  "properties": {
    "contractVersion": { "const": "cornerops-cornermex-catalog-export-v1" },
    "sourceRepoSha": { "type": "string" },
    "sourceFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sourceCount": { "type": "integer", "minimum": 0 },
    "records": { "type": "array" }
  }
}
