{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cornermex-catalog-import-execution-v1",
  "type": "object",
  "required": [
    "contractVersion",
    "sourceFingerprint",
    "targetProject",
    "reviewedCommit",
    "idempotencyKey",
    "rollbackScope"
  ],
  "properties": {
    "contractVersion": { "const": "cornermex-catalog-import-execution-v1" },
    "sourceFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "targetProject": { "const": "wlrfknmrhowldygmvtvn" },
    "reviewedCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "idempotencyKey": { "type": "string", "minLength": 16 }
  }
}
